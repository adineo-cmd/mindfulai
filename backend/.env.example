# Database
# Option 1: PostgreSQL (if you have it installed and running)
#DATABASE_URL=postgresql://user:password@localhost:5432/mindfulai

# Option 2: SQLite (easier for local dev - just uncomment this and comment out the line above)
DATABASE_URL=sqlite:///./mindfulai.db

# Security
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
FRONTEND_URL=http://localhost:4321

# Open Source LLM Configuration (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=tinyllama  # You have this installed! Can also use "mistral" or "llama2"