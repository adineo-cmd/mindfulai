---
const currentPath = Astro.url.pathname;
const links = [
  { href: '/', label: 'Home' },
  { href: '/dashboard', label: 'Dashboard' },
  { href: '/live-check', label: 'Live Check' },
  { href: '/chat', label: 'Companion' },
  { href: '/journal', label: 'Journal' },
  { href: '/trends', label: 'Trends' },
  { href: '/settings', label: 'Settings' },
];
---

<header class="sticky top-0 z-50 w-full border-b border-slate-200 bg-white/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-2">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-sage-600 text-white font-bold">M</div>
      <span class="text-lg font-semibold text-slate-900">MindfulAI</span>
    </a>
    
    <nav class="hidden md:flex items-center gap-1">
      {links.map(link => (
        <a 
          href={link.href} 
          class={`rounded-lg px-3 py-2 text-sm font-medium transition-colors ${
            currentPath === link.href 
              ? 'bg-sage-100 text-sage-800' 
              : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <a href="/dashboard" class="md:hidden btn-primary text-xs py-2 px-3">Dashboard</a>
  </div>
</header>