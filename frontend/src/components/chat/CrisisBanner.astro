---
interface Props {
  message?: string;
}
const { message = "We've detected signs of severe distress. Your safety is our priority." } = Astro.props;
---

<div class="rounded-xl bg-red-50 border border-red-200 p-4 mb-4 animate-in fade-in slide-in-from-top-2">
  <div class="flex gap-3">
    <div class="flex-shrink-0">
      <svg class="h-5 w-5 text-red-600" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
      </svg>
    </div>
    <div class="flex-1">
      <h3 class="text-sm font-semibold text-red-900">Support Resources Available</h3>
      <p class="mt-1 text-sm text-red-800">{message}</p>
      <div class="mt-3 flex flex-wrap gap-3">
        <a href="tel:988" class="inline-flex items-center rounded-lg bg-red-600 px-3 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2">
          Call 988 (Suicide & Crisis Lifeline)
        </a>
        <a href="https://www.crisistextline.org/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center rounded-lg bg-white px-3 py-1.5 text-xs font-semibold text-red-700 shadow-sm ring-1 ring-inset ring-red-300 hover:bg-red-50">
          Text HOME to 741741
        </a>
      </div> <!-- FIX: Added the missing > -->
    </div>
  </div>
</div>