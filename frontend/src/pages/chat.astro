---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChatWindow from '../components/chat/ChatWindow.tsx';
---

<BaseLayout title="Companion Chat">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-slate-900">Your Companion</h1>
      <p class="text-slate-600 mt-1">A safe space to talk. I'm here to listen without judgment.</p>
    </div>
    <ChatWindow client:load />
  </div>
</BaseLayout>