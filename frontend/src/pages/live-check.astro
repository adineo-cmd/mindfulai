---
import BaseLayout from '../layouts/BaseLayout.astro';
import WebcamPanel from '../components/camera/WebcamPanel.tsx';
---

<BaseLayout title="Live Check-in">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-8 text-center">
      <h1 class="text-2xl font-bold text-slate-900">Camera-Based Mood Check</h1>
      <p class="text-slate-600 mt-2 max-w-xl mx-auto">
        Allow us to analyze your facial expressions to provide a gentle, objective snapshot of your current emotional state. 
        You are always in control.
      </p>
    </div>
    
    <div class="max-w-lg mx-auto">
      <WebcamPanel client:load />
    </div>
  </div>
</BaseLayout>